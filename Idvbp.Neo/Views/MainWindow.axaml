<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:Idvbp.Neo.Controls"
        xmlns:ic="clr-namespace:FluentIcons.Avalonia.Fluent;assembly=FluentIcons.Avalonia.Fluent"
        mc:Ignorable="d"
        d:DesignWidth="980"
        d:DesignHeight="760"
        x:Class="Idvbp.Neo.Views.MainWindow"
             x:CompileBindings="False"
        Title="Backend"
        Width="980"
        Height="760"
        MinWidth="900"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ApplicationPageBackgroundThemeBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="35">

    <Grid>
        <Grid RowDefinitions="35,Auto,*">
            <WrapPanel Grid.Row="1"
                       Margin="10,10,0,0"
                       Orientation="Horizontal">
                <Border Width="360" Classes="Card">
                    <Grid RowDefinitions="Auto,Auto,Auto">
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="当前求生者队伍：" />
                            <TextBlock Margin="20,0,0,0" Text="{Binding CurrentGame.SurTeam.Name}" />
                        </StackPanel>
                        <Button Grid.Row="1"
                                Margin="0,10,0,10"
                                HorizontalAlignment="Center"
                                Command="{Binding SwapCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:FluentIcon Icon="ArrowSort" FontSize="18"/>
                                <TextBlock Text="交换"/>
                            </StackPanel>
                        </Button>
                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <TextBlock Text="当前监管者队伍：" />
                            <TextBlock Margin="20,0,0,0" Text="{Binding CurrentGame.HunTeam.Name}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Width="390" Classes="Card">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" Text="倒计时" />
                        <StackPanel Grid.Row="1"
                                    Margin="0,10,0,0"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                            <ComboBox Width="100"
                                      IsEditable="True"
                                      ItemsSource="{Binding RecommendTimerList}"
                                      SelectedIndex="0"
                                      Text="{Binding TimerTime}" />
                            <Button Margin="10,0,0,0" Command="{Binding TimerStartCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ic:FluentIcon Icon="Play" FontSize="18"/>
                                    <TextBlock Text="开始"/>
                                </StackPanel>
                            </Button>
                            <Button Margin="10,0,0,0" Command="{Binding TimerStopCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ic:FluentIcon Icon="Stop" FontSize="18"/>
                                    <TextBlock Text="停止"/>
                                </StackPanel>
                            </Button>
                            <TextBlock Width="60" Margin="10,0,0,0" VerticalAlignment="Center" Text="预览：" />
                            <TextBlock Width="30" Margin="10,0,0,0" VerticalAlignment="Center" Text="{Binding RemainingSeconds}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Button Margin="0,0,10,10" Command="{Binding SaveGameInfoCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ic:FluentIcon Icon="Save" FontSize="18"/>
                        <TextBlock Text="保存比赛信息"/>
                    </StackPanel>
                </Button>
                <Button Margin="0,0,10,10" Command="{Binding ImportGameInfoCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ic:FluentIcon Icon="FolderOpen" FontSize="18"/>
                        <TextBlock Text="导入比赛信息"/>
                    </StackPanel>
                </Button>
                <Button Margin="0,0,10,10" Command="{Binding NewGameCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ic:FluentIcon Icon="Add" FontSize="18"/>
                        <TextBlock Text="新建比赛"/>
                    </StackPanel>
                </Button>
                <Border Classes="Card">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" Text="赛制：" />
                        <RadioButton Margin="10,0,0,0" Content="BO5" GroupName="Bo3Mode" IsChecked="True" />
                        <RadioButton Content="BO3" GroupName="Bo3Mode" IsChecked="{Binding IsBo3Mode}" />
                    </StackPanel>
                </Border>
                <TextBlock Margin="0,0,10,10" VerticalAlignment="Center" Text="游戏进度：" />
                <ComboBox Width="215"
                          Margin="0,0,10,10"
                          ItemsSource="{Binding GameList}"
                          SelectedIndex="0"
                          SelectedItem="{Binding SelectedGameProgress}" />
                <Button Margin="0,0,10,10" Command="{Binding NextGameCommand}" Content="下一局" />
                <Button Margin="0,0,10,10" Command="{Binding StartNavigationCommand}" Content="开始对局引导" />
                <Button Margin="0,0,10,10" Command="{Binding NavigateToPreviousStepCommand}" Content="上一步" />
                <Button Margin="0,0,10,10" Command="{Binding NavigateToNextStepCommand}" Content="下一步" />
                <Button Margin="0,0,10,10" Command="{Binding StopNavigationCommand}" Content="结束对局引导" />
                <TextBlock Margin="0,0,10,10" VerticalAlignment="Center" Text="{Binding ActionName}" />
            </WrapPanel>

            <Grid Grid.Row="2">
                <controls:NavigationView
                    x:Name="RootNavigation"
                    AlwaysShowHeader="False"
                    IsBackEnabled="False"
                    IsPaneToggleButtonVisible="True"
                    IsPaneOpen="True"
                    MenuItemsSource="{Binding MenuItems}"
                    FooterMenuItemsSource="{Binding FooterMenuItems}"
                    OpenPaneLength="200"
                    PaneDisplayMode="Left"
                    IsSettingsVisible="False"
                    SelectedItem="{Binding NavigationSelectedItem}">
                    <ScrollViewer>
                        <controls:Frame x:Name="ContentFrame" />
                    </ScrollViewer>
                </controls:NavigationView>
            </Grid>
        </Grid>
    </Grid>
</Window>
