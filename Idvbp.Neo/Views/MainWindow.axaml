<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:Idvbp.Neo.Controls"
        xmlns:converters="clr-namespace:Idvbp.Neo.Converters"
        xmlns:ic="clr-namespace:FluentIcons.Avalonia.Fluent;assembly=FluentIcons.Avalonia.Fluent"
        mc:Ignorable="d"
        d:DesignWidth="980"
        d:DesignHeight="760"
        x:Class="Idvbp.Neo.Views.MainWindow"
             x:CompileBindings="False"
        Title="Backend"
        Width="980"
        Height="760"
        MinWidth="900"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ApplicationPageBackgroundThemeBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="35">

    <Window.Resources>
        <converters:AppNotificationSeverityBrushConverter x:Key="NotificationBrushConverter" />
    </Window.Resources>

    <Grid>
        <Grid RowDefinitions="35,Auto,*">
            <WrapPanel Grid.Row="1"
                       Margin="10,10,0,0"
                       Orientation="Horizontal">
                <Border Width="360" Classes="Card">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="当前求生者队伍：" />
                            <TextBlock Margin="20,0,0,0" Text="{Binding Workspace.SurvivorTeamName}" />
                        </StackPanel>
                        <Button Grid.Row="1"
                                Margin="0,10,0,10"
                                HorizontalAlignment="Center"
                                Command="{Binding SwapCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:FluentIcon Icon="ArrowSort" FontSize="18"/>
                                <TextBlock Text="交换"/>
                            </StackPanel>
                        </Button>
                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <TextBlock Text="当前监管者队伍：" />
                            <TextBlock Margin="20,0,0,0" Text="{Binding Workspace.HunterTeamName}" />
                        </StackPanel>
                        <TextBlock Grid.Row="3" Margin="0,10,0,0" Text="{Binding Workspace.CurrentRoomTitle}" TextWrapping="Wrap" />
                    </Grid>
                </Border>

                <Border Width="560" Classes="Card">
                    <Grid RowDefinitions="Auto,Auto,Auto">
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Text="比赛房间：" />
                            <ComboBox Width="260" Margin="10,0,0,0" ItemsSource="{Binding Workspace.Rooms}" SelectedItem="{Binding Workspace.SelectedRoom}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RoomName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Margin="10,0,0,0" Command="{Binding RefreshRoomsCommand}" Content="刷新" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Margin="0,10,0,0" Orientation="Horizontal">
                            <TextBox Width="150" Watermark="比赛名称" Text="{Binding RoomName}" />
                            <TextBox Width="120" Margin="10,0,0,0" Watermark="主队" Text="{Binding TeamAName}" />
                            <TextBox Width="120" Margin="10,0,0,0" Watermark="客队" Text="{Binding TeamBName}" />
                            <Button Margin="10,0,0,0" Command="{Binding NewGameCommand}" Content="新建比赛" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Margin="0,10,0,0" Orientation="Horizontal">
                            <CheckBox Content="下一局重置全局 Ban" IsChecked="{Binding ResetGlobalBansOnNextMatch}" />
                            <Button Margin="10,0,0,0" Command="{Binding NextGameCommand}" Content="新开一局" />
                            <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Text="{Binding Workspace.StatusMessage}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Width="390" Classes="Card">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" Text="倒计时" />
                        <StackPanel Grid.Row="1"
                                    Margin="0,10,0,0"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                            <ComboBox Width="100"
                                      IsEditable="True"
                                      ItemsSource="{Binding RecommendTimerList}"
                                      SelectedIndex="0"
                                      Text="{Binding TimerTime}" />
                            <Button Margin="10,0,0,0" Command="{Binding TimerStartCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ic:FluentIcon Icon="Play" FontSize="18"/>
                                    <TextBlock Text="开始"/>
                                </StackPanel>
                            </Button>
                            <Button Margin="10,0,0,0" Command="{Binding TimerStopCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ic:FluentIcon Icon="Stop" FontSize="18"/>
                                    <TextBlock Text="停止"/>
                                </StackPanel>
                            </Button>
                            <TextBlock Width="60" Margin="10,0,0,0" VerticalAlignment="Center" Text="预览：" />
                            <TextBlock Width="30" Margin="10,0,0,0" VerticalAlignment="Center" Text="{Binding RemainingSeconds}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Button Margin="0,0,10,10" Command="{Binding SaveGameInfoCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ic:FluentIcon Icon="Save" FontSize="18"/>
                        <TextBlock Text="保存比赛信息"/>
                    </StackPanel>
                </Button>
                <Button Margin="0,0,10,10" Command="{Binding ImportGameInfoCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ic:FluentIcon Icon="FolderOpen" FontSize="18"/>
                        <TextBlock Text="导入比赛信息"/>
                    </StackPanel>
                </Button>
                <Border Classes="Card">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" Text="赛制：" />
                        <RadioButton Margin="10,0,0,0" Content="BO5" GroupName="Bo3Mode" IsChecked="True" />
                        <RadioButton Content="BO3" GroupName="Bo3Mode" IsChecked="{Binding IsBo3Mode}" />
                    </StackPanel>
                </Border>
                <TextBlock Margin="0,0,10,10" VerticalAlignment="Center" Text="游戏进度：" />
                <ComboBox Width="215"
                          Margin="0,0,10,10"
                          ItemsSource="{Binding GameList}"
                          SelectedIndex="0"
                          SelectedItem="{Binding SelectedGameProgress}" />
                <Button Margin="0,0,10,10" Command="{Binding NextGameCommand}" Content="下一局" />
                <Button Margin="0,0,10,10" Command="{Binding StartNavigationCommand}" Content="开始对局引导" />
                <Button Margin="0,0,10,10" Command="{Binding NavigateToPreviousStepCommand}" Content="上一步" />
                <Button Margin="0,0,10,10" Command="{Binding NavigateToNextStepCommand}" Content="下一步" />
                <Button Margin="0,0,10,10" Command="{Binding StopNavigationCommand}" Content="结束对局引导" />
                <TextBlock Margin="0,0,10,10" VerticalAlignment="Center" Text="{Binding ActionName}" />
            </WrapPanel>

            <Grid Grid.Row="2">
                <controls:NavigationView
                    x:Name="RootNavigation"
                    AlwaysShowHeader="False"
                    IsBackEnabled="False"
                    IsPaneToggleButtonVisible="True"
                    IsPaneOpen="True"
                    MenuItemsSource="{Binding MenuItems}"
                    FooterMenuItemsSource="{Binding FooterMenuItems}"
                    OpenPaneLength="200"
                    PaneDisplayMode="Left"
                    IsSettingsVisible="False"
                    SelectedItem="{Binding NavigationSelectedItem}">
                    <ScrollViewer>
                        <controls:Frame x:Name="ContentFrame" />
                    </ScrollViewer>
                </controls:NavigationView>
            </Grid>
        </Grid>

        <Border Background="#CC000000"
                IsVisible="{Binding Workspace.IsSwitchingRoom}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="14">
                <ProgressBar Width="320" IsIndeterminate="True" />
                <TextBlock HorizontalAlignment="Center"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Text="正在切换房间" />
                <TextBlock HorizontalAlignment="Center"
                           Foreground="#DDFFFFFF"
                           Text="正在重置页面状态并同步最新快照..." />
            </StackPanel>
        </Border>
        <ItemsControl Width="360"
                      Margin="0,0,18,18"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      ItemsSource="{Binding Notifications.Notifications}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Spacing="10" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Classes="ToastCard"
                            Background="{Binding Severity, Converter={StaticResource NotificationBrushConverter}}"
                            BorderBrush="{Binding Severity, Converter={StaticResource NotificationBrushConverter}, ConverterParameter=Accent}"
                            BorderThickness="1">
                        <Grid ColumnDefinitions="4,*,Auto">
                            <Border Grid.Column="0"
                                    Width="4"
                                    CornerRadius="4"
                                    Background="{Binding Severity, Converter={StaticResource NotificationBrushConverter}, ConverterParameter=Accent}" />
                            <StackPanel Grid.Column="1"
                                        Margin="10,0,8,0"
                                        Spacing="4">
                                <TextBlock Classes="ToastTitle" Text="{Binding Title}" />
                                <TextBlock Classes="ToastMessage" Text="{Binding Message}" />
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Width="28"
                                    Height="28"
                                    Padding="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Command="{Binding DismissCommand}">
                                <ic:FluentIcon Icon="Dismiss" FontSize="14" />
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>
