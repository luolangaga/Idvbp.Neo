<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Idvbp.Neo.ViewModels.Pages"
             x:Class="Idvbp.Neo.Views.Pages.SettingPage"
             x:DataType="vm:SettingPageViewModel">

    <Design.DataContext>
        <vm:SettingPageViewModel/>
    </Design.DataContext>

    <ScrollViewer>
        <StackPanel Margin="12">

            <!-- Language Settings -->
            <TextBlock Classes="PageTitle" Text="语言设置"/>
            <Border Classes="Card" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="界面语言" FontSize="13"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding LanguageList}"
                              SelectedItem="{Binding SelectedLanguage}"
                              PlaceholderText="选择语言"/>
                </StackPanel>
            </Border>

            <!-- About -->
            <TextBlock Classes="PageTitle" Text="关于" Margin="0,0,0,12"/>
            <Expander Padding="0" Margin="0,0,0,16">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Idvbp.Neo" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="{Binding AppVersion}"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>
                    </StackPanel>
                </Expander.Header>
                <StackPanel Margin="0,12,0,0">
                    <TextBlock Text="作者: YourName" FontSize="13" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Text="现代化的第五人格BP辅助工具" FontSize="13"
                               TextWrapping="Wrap" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBlock FontSize="13" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                        <Run Text="许可证: "/>
                        <Button Content="MIT License" Classes="Hyperlink"/>
                    </TextBlock>
                    <TextBlock FontSize="13" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                        <Run Text=".NET 版本: "/>
                        <Run Text="10.0"/>
                    </TextBlock>
                    <TextBlock FontSize="12" Margin="0,0,0,16"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                        <Run Text="Copyright © "/>
                        <Run Text="{Binding AppVersion}"/>
                    </TextBlock>

                    <!-- Software Update -->
                    <TextBlock Text="软件更新" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="0,0,0,10"/>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="更新源" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,6"/>
                        <ComboBox ItemsSource="{Binding MirrorList}"
                                  SelectedItem="{Binding Mirror}"
                                  PlaceholderText="选择更新源"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="预览版本" FontSize="13" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ToggleSwitch IsChecked="{Binding IsFindPreRelease}" Margin="8,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="检查更新" Margin="0,0,8,0"/>
                        <Button Content="安装更新"/>
                    </StackPanel>
                    <StackPanel IsVisible="{Binding IsDownloading}" Margin="0,0,0,16">
                        <ProgressBar IsIndeterminate="{Binding !IsDownloading}"
                                     Margin="0,0,0,6"/>
                        <ProgressBar Value="{Binding DownloadProgress}"
                                     Maximum="100"
                                     Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding DownloadProgressText}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBlock FontSize="12" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="速度: "/>
                            <Run Text="{Binding MbPerSecondSpeed}"/>
                        </TextBlock>
                        <Button Content="取消下载"/>
                    </StackPanel>

                    <!-- Image Sources -->
                    <TextBlock Text="图片来源" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="BWIKI" Classes="Hyperlink" Margin="0,0,8,0"/>
                        <Button Content="Fandom Wiki" Classes="Hyperlink"/>
                    </StackPanel>

                    <!-- Open Source Repos -->
                    <TextBlock Text="使用的开源仓库" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="0,0,0,10"/>
                    <Grid RowDefinitions="Auto"
                          ColumnDefinitions="*,*,*"
                          Margin="0,0,0,16">
                        <StackPanel>
                            <Button Content="Avalonia" Classes="Hyperlink" Margin="0,0,0,4"/>
                            <Button Content="CommunityToolkit" Classes="Hyperlink" Margin="0,0,0,4"/>
                            <Button Content=".NET" Classes="Hyperlink"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <Button Content="OpenCV" Classes="Hyperlink" Margin="0,0,0,4"/>
                            <Button Content="PaddleOCR" Classes="Hyperlink" Margin="0,0,0,4"/>
                            <Button Content="Tesseract" Classes="Hyperlink"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <Button Content="SignalR" Classes="Hyperlink" Margin="0,0,0,4"/>
                            <Button Content="WebView2" Classes="Hyperlink" Margin="0,0,0,4"/>
                            <Button Content="WPF-UI" Classes="Hyperlink"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Expander>

            <!-- Quick Access -->
            <TextBlock Classes="PageTitle" Text="快速访问"/>
            <Border Classes="Card" Margin="0,0,0,16">
                <StackPanel>
                    <Button Content="打开前端目录" Margin="0,0,0,8"/>
                    <Button Content="打开比赛文件目录"/>
                </StackPanel>
            </Border>

            <!-- Custom Frontend UI -->
            <TextBlock Classes="PageTitle" Text="自定义前端UI"/>
            <Border Classes="Card" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="导出UI配置" Margin="0,0,8,0"/>
                        <Button Content="导入UI配置"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- BP Window -->
            <Expander Padding="0" Margin="0,0,0,8">
                <Expander.Header>
                    <TextBlock Text="BP窗口" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                </Expander.Header>
                <StackPanel Margin="0,12,0,0">
                    <Button Content="编辑背景图片" Margin="0,0,0,8"/>
                    <TextBlock Text="颜色选择器 (暂未实现)"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="窗口透明度" VerticalAlignment="Center" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ToggleSwitch Margin="8,0,0,0"/>
                    </StackPanel>
                    <ComboBox PlaceholderText="窗口大小" Margin="0,0,0,8"/>
                    <Button Content="编辑文本设置" Margin="0,0,0,8"/>
                    <Button Content="重置默认设置"/>
                </StackPanel>
            </Expander>

            <!-- CutScene Window -->
            <Expander Padding="0" Margin="0,0,0,8">
                <Expander.Header>
                    <TextBlock Text="转场窗口" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                </Expander.Header>
                <StackPanel Margin="0,12,0,0">
                    <Button Content="编辑背景图片" Margin="0,0,0,8"/>
                    <TextBlock Text="颜色选择器 (暂未实现)"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="窗口透明度" VerticalAlignment="Center" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ToggleSwitch Margin="8,0,0,0"/>
                    </StackPanel>
                    <ComboBox PlaceholderText="窗口大小" Margin="0,0,0,8"/>
                    <Button Content="编辑文本设置" Margin="0,0,0,8"/>
                    <Button Content="重置默认设置"/>
                </StackPanel>
            </Expander>

            <!-- Score Window -->
            <Expander Padding="0" Margin="0,0,0,8">
                <Expander.Header>
                    <TextBlock Text="计分组件" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                </Expander.Header>
                <StackPanel Margin="0,12,0,0">
                    <Button Content="编辑背景图片" Margin="0,0,0,8"/>
                    <TextBlock Text="颜色选择器 (暂未实现)"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="窗口透明度" VerticalAlignment="Center" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ToggleSwitch Margin="8,0,0,0"/>
                    </StackPanel>
                    <ComboBox PlaceholderText="窗口大小" Margin="0,0,0,8"/>
                    <Button Content="编辑文本设置" Margin="0,0,0,8"/>
                    <Button Content="重置默认设置"/>
                </StackPanel>
            </Expander>

            <!-- GameData Window -->
            <Expander Padding="0" Margin="0,0,0,8">
                <Expander.Header>
                    <TextBlock Text="赛后数据窗口" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                </Expander.Header>
                <StackPanel Margin="0,12,0,0">
                    <Button Content="编辑背景图片" Margin="0,0,0,8"/>
                    <TextBlock Text="颜色选择器 (暂未实现)"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="窗口透明度" VerticalAlignment="Center" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ToggleSwitch Margin="8,0,0,0"/>
                    </StackPanel>
                    <ComboBox PlaceholderText="窗口大小" Margin="0,0,0,8"/>
                    <Button Content="编辑文本设置" Margin="0,0,0,8"/>
                    <Button Content="重置默认设置"/>
                </StackPanel>
            </Expander>

            <!-- Widgets Window -->
            <Expander Padding="0" Margin="0,0,0,8">
                <Expander.Header>
                    <TextBlock Text="组件窗口" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                </Expander.Header>
                <StackPanel Margin="0,12,0,0">
                    <Button Content="编辑背景图片" Margin="0,0,0,8"/>
                    <TextBlock Text="颜色选择器 (暂未实现)"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="窗口透明度" VerticalAlignment="Center" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ToggleSwitch Margin="8,0,0,0"/>
                    </StackPanel>
                    <ComboBox PlaceholderText="窗口大小" Margin="0,0,0,8"/>
                    <Button Content="编辑文本设置" Margin="0,0,0,8"/>
                    <Button Content="重置默认设置"/>
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>

</UserControl>
