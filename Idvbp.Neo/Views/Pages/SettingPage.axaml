<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Idvbp.Neo.Views.Pages.SettingPage"
             x:CompileBindings="False"
             Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <StackPanel Margin="10,0,10,0">
        <TextBlock Classes="Title" Text="语言设置" />
        <Border Classes="Card">
            <ComboBox Width="300"
                      Margin="0,10,0,0"
                      HorizontalAlignment="Left"
                      ItemsSource="{Binding LanguageList}"
                      SelectedItem="{Binding SelectedLanguage}" />
        </Border>

        <TextBlock Margin="0,10,0,0" Classes="Title" Text="官方 3D 模型" />
        <Border Classes="Card" Padding="10">
            <StackPanel>
                <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="从官方模型列表解析角色 glTF，缺失时下载到 wwwroot/official-models。前台 3D 页面也会按角色按需下载，这里可以提前补齐。"
                           TextWrapping="Wrap" />
                <StackPanel Margin="0,10,0,0" Orientation="Horizontal" Spacing="10">
                    <Button Command="{Binding EnsureOfficialModelsCommand}" Content="补齐官方模型" />
                    <Button Command="{Binding CancelOfficialModelDownloadCommand}" Content="停止" />
                    <ProgressBar Width="220" Height="20" Value="{Binding ModelDownloadProgress}" />
                    <TextBlock VerticalAlignment="Center" Text="{Binding ModelDownloadProgressText}" />
                </StackPanel>
                <TextBlock Margin="0,8,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding ModelDownloadStageText}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <TextBlock Margin="0,10,0,0" Classes="Title" Text="关于" />
        <StackPanel Margin="0,10,0,0">
            <Expander IsExpanded="True">
                <Expander.Header>
                    <Grid>
                        <Grid HorizontalAlignment="Left" RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Row="0" FontSize="18" Text="Idvbp.Neo" />
                            <TextBlock Grid.Row="1" Margin="0,5,0,0" VerticalAlignment="Center" FontSize="12" Text="AuthorDetails" />
                        </Grid>
                        <TextBlock Margin="0,0,10,0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding AppVersion}" />
                    </Grid>
                </Expander.Header>
                <StackPanel>
                    <Grid>
                        <TextBlock HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="12"
                                   Text="Idvbp.Neo is licenced under GPLv3 licence" />
                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                            <TextBlock Text="Powered by" />
                            <TextBlock Margin="5,0,5,0" Text=".NET &amp; Avalonia" />
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,10,0,0" ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="项目仓库" />
                        <HyperlinkButton Grid.Column="1" Content="https://github.com/AyaSlinc/Idvbp.Neo" />
                    </Grid>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock FontSize="16" FontWeight="Bold" Text="软件更新" />
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Text="下载源" />
                            <ComboBox Margin="10,0,0,0" ItemsSource="{Binding MirrorList}" SelectedItem="{Binding Mirror}" />
                            <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Text="下载预览版本" />
                            <CheckBox Margin="10,0,0,0" IsChecked="{Binding IsFindPreRelease}" />
                        </StackPanel>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Button Command="{Binding UpdateCheckCommand}" Content="检查更新" />
                            <Button Margin="10,0,0,0" Command="{Binding InstallUpdateCommand}" Content="安装" />
                            <ProgressBar Width="175" Height="20" Margin="10,0,0,0" Value="{Binding DownloadProgress}" />
                            <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Text="{Binding DownloadProgressText}" />
                            <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Text="{Binding MbPerSecondSpeed}" />
                            <Button Margin="10,0,0,0" Command="{Binding CancelDownloadCommand}" Content="停止" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Margin="0,20,0,0" FontWeight="DemiBold" Text="图片资源来源" />
                    <WrapPanel Margin="0,10,0,0" Orientation="Horizontal">
                        <Button Margin="0,0,10,10" Content="第五人格BWiki" />
                        <Button Margin="0,0,10,10" Content="Fandom Identity V Wiki" />
                    </WrapPanel>
                </StackPanel>
            </Expander>
        </StackPanel>

        <TextBlock Margin="0,10,0,0" Classes="Title" Text="快速访问" />
        <Border Margin="0,10,0,0" Padding="10,10,0,0" Classes="Card">
            <WrapPanel>
                <Button Margin="0,0,10,10" Command="{Binding HopToConfigDirCommand}" Content="打开配置文件目录" />
            </WrapPanel>
        </Border>

        <TextBlock Margin="0,10,0,0" Classes="Title" Text="调试选项" />
        <Border Margin="0,10,0,0" Padding="10,10,0,0" Classes="Card">
            <StackPanel>
                <StackPanel Margin="0,0,10,10" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Text="日志等级" />
                    <ComboBox Width="220" Margin="10,0,0,0" ItemsSource="{Binding LogLevelOptions}" SelectedItem="{Binding SelectedLogLevel}" />
                </StackPanel>
                <WrapPanel Orientation="Horizontal">
                    <Button Margin="0,0,10,10" Command="{Binding ManualGcCommand}" Content="手动触发 GC" />
                    <Button Margin="0,0,10,10" Command="{Binding SwitchDebugGlobalScoreCommand}" Content="切换分数统计调试表格" />
                    <Button Margin="0,0,10,10" Command="{Binding OpenTipCommand}" Content="打开启动时无作者 UI 提示" />
                    <Button Margin="0,0,10,10" Command="{Binding HopToLogDirCommand}" Content="打开日志目录" />
                </WrapPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
