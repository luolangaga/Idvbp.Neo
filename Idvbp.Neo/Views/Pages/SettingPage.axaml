<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Idvbp.Neo.Views.Pages.SettingPage"
             x:CompileBindings="False"
             Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <ScrollViewer Classes="PageScroll">
        <StackPanel Spacing="16">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Text="设置" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="管理资源、项目信息和调试工具。" />
                </StackPanel>
                <Button Grid.Column="1"
                        VerticalAlignment="Top"
                        Command="{Binding RefreshContributorsCommand}"
                        Content="刷新贡献者" />
            </Grid>

            <Border Classes="Card"
                    Padding="18">
                <Grid ColumnDefinitions="*,Auto"
                      RowDefinitions="Auto,Auto,Auto">
                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Spacing="4">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="官方 3D 模型" />
                        <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="从官方模型列表解析角色 glTF，并下载到 wwwroot/official-models。"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="10">
                        <Button Command="{Binding EnsureOfficialModelsCommand}"
                                Content="补齐模型" />
                        <Button Command="{Binding CancelOfficialModelDownloadCommand}"
                                Content="停止" />
                    </StackPanel>

                    <ProgressBar Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Height="8"
                                 Margin="0,16,0,0"
                                 Value="{Binding ModelDownloadProgress}" />
                    <Grid Grid.Row="2"
                          Grid.ColumnSpan="2"
                          Margin="0,8,0,0"
                          ColumnDefinitions="*,Auto">
                        <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding ModelDownloadStageText}"
                                   TextWrapping="Wrap" />
                        <TextBlock Grid.Column="1"
                                   Margin="12,0,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding ModelDownloadProgressText}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Classes="Card"
                    Padding="18">
                <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="*,260">
                        <StackPanel Grid.Column="0"
                                    Spacing="4">
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="GitHub 代理" />
                            <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Text="更新服务、组件包下载服务和 GitHub 信息加载可以复用这里选择的访问方式。默认代理从 github-proxies.json 读取，开发者可直接修改该文件。"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding GitHubProxyEndpoints}"
                                  SelectedItem="{Binding SelectedGitHubProxyEndpoint}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding GitHubProxyStatus}"
                               TextWrapping="Wrap" />

                    <Grid ColumnDefinitions="180,*,Auto"
                          ColumnSpacing="10">
                        <TextBox Grid.Column="0"
                                 Watermark="自定义名称"
                                 Text="{Binding CustomGitHubProxyName}" />
                        <TextBox Grid.Column="1"
                                 Watermark="代理地址，例如 https://gh-proxy.com/{url}"
                                 Text="{Binding CustomGitHubProxyUrl}" />
                        <Button Grid.Column="2"
                                Command="{Binding AddCustomGitHubProxyCommand}"
                                Content="添加代理" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="Card"
                    Padding="18">
                <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel>
                            <TextBlock FontSize="20"
                                       FontWeight="SemiBold"
                                       Text="Idvbp.Neo" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Text="第五人格赛事直播工具" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Top"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding AppVersion}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding CopyrightText}" />
                            <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Text="Licensed under GNU GPLv3. Powered by .NET and Avalonia." />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding OpenRepositoryCommand}"
                                Content="打开仓库" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="Card"
                    Padding="18">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="开发者贡献榜" />
                            <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Text="{Binding ContributorsStatus}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ProgressBar Grid.Column="1"
                                     Width="120"
                                     Height="6"
                                     VerticalAlignment="Center"
                                     IsIndeterminate="{Binding IsLoadingContributors}" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Contributors}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="260"
                                        MinHeight="132"
                                        Margin="0,0,12,12"
                                        Padding="12"
                                        Background="{DynamicResource LayerFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <Grid ColumnDefinitions="56,*"
                                          RowDefinitions="Auto,Auto,Auto">
                                        <Border Width="48"
                                                Height="48"
                                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                                CornerRadius="24">
                                            <Image Source="{Binding Avatar}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    Spacing="2">
                                            <TextBlock FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding DisplayName}" />
                                            <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Text="{Binding Login}" />
                                        </StackPanel>
                                        <TextBlock Grid.Row="1"
                                                   Grid.ColumnSpan="2"
                                                   Margin="0,10,0,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   MaxHeight="42"
                                                   Text="{Binding Bio}"
                                                   TextWrapping="Wrap" />
                                        <Grid Grid.Row="2"
                                              Grid.ColumnSpan="2"
                                              Margin="0,10,0,0"
                                              ColumnDefinitions="*,Auto">
                                            <TextBlock Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Text="{Binding ContributionsText}" />
                                            <Button Grid.Column="1"
                                                    Command="{Binding OpenProfileCommand}"
                                                    Content="主页" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="16">
                <Border Grid.Column="0"
                        Classes="Card"
                        Padding="18">
                    <StackPanel Spacing="12">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="快速访问" />
                        <WrapPanel>
                            <Button Margin="0,0,10,10"
                                    Command="{Binding OpenConfigDirectoryCommand}"
                                    Content="配置目录" />
                            <Button Margin="0,0,10,10"
                                    Command="{Binding OpenLogDirectoryCommand}"
                                    Content="日志目录" />
                            <Button Margin="0,0,10,10"
                                    Command="{Binding OpenLogViewerCommand}"
                                    Content="日志查看器" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Classes="Card"
                        Padding="18">
                    <StackPanel Spacing="12">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="调试" />
                        <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding DebugStatus}"
                                   TextWrapping="Wrap" />
                        <WrapPanel>
                            <Button Margin="0,0,10,10"
                                    Command="{Binding ManualGcCommand}"
                                    Content="手动 GC" />
                            <Button Margin="0,0,10,10"
                                    Command="{Binding ThrowTestErrorCommand}"
                                    Content="抛出测试错误" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
