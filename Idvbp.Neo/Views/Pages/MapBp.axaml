<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Idvbp.Neo.Views.Pages.MapBp"
             x:CompileBindings="False"
             Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <Grid>
        <ScrollViewer Classes="PageScroll">
            <StackPanel Spacing="12">
                <Border Classes="Card">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" RowDefinitions="Auto,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Classes="PageTitle" Text="地图 BP" />
                            <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{Binding CurrentRoomTitle}" />
                            <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                        </StackPanel>
                        <CheckBox Grid.Column="1" VerticalAlignment="Center" Content="选择框" IsChecked="{Binding IsBreathing}" />
                        <CheckBox Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center" Content="阵营" IsChecked="{Binding IsCampVisible}" />
                        <Button Grid.Column="3" Margin="12,0,0,0" Command="{Binding RefreshCommand}" Content="刷新" />
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="360,*" ColumnSpacing="12">
                    <Border Grid.Column="0" Classes="Card">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="SectionTitle" Text="选择地图" />
                            <ComboBox ItemsSource="{Binding MapSelectTeamsList}" SelectedItem="{Binding PickMapTeam}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TeamName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <ComboBox ItemsSource="{Binding MapOptions}" SelectedItem="{Binding PickedMap}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Command="{Binding PickMapCommand}" Content="确认选择" IsEnabled="{Binding HasSelectedRoom}" />
                            <Button Command="{Binding ResetLocalSelectionCommand}" Content="重置本页选择" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Classes="Card">
                        <Grid RowDefinitions="Auto,Auto,*">
                            <Grid Grid.Row="0" ColumnDefinitions="*,240">
                                <TextBlock Classes="SectionTitle" Text="禁用地图" />
                                <ComboBox Grid.Column="1" ItemsSource="{Binding MapSelectTeamsList}" SelectedItem="{Binding BanMapTeam}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TeamName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                            <ItemsControl Grid.Row="1" Margin="0,10,0,0" ItemsSource="{Binding BannedMapList}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,8,8" Padding="8" Classes="Card">
                                            <TextBlock Text="{Binding Name}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl Grid.Row="2" Margin="0,10,0,0" ItemsSource="{Binding MapOptions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Width="230"
                                                Height="96"
                                                Margin="0,0,10,10"
                                                Command="{Binding DataContext.BanMapCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding CanBeBanned}">
                                            <Grid RowDefinitions="*,Auto">
                                                <Image Grid.Row="0" Source="{Binding ImageUrl}" Stretch="UniformToFill" />
                                                <TextBlock Grid.Row="1" HorizontalAlignment="Center" Text="{Binding Name}" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Border Background="#AA000000" IsVisible="{Binding IsBusy}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <ProgressBar Width="260" IsIndeterminate="True" />
                <TextBlock Foreground="White" FontSize="18" Text="正在同步房间状态..." />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
