<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Idvbp.Neo.Views.Pages.FrontManagePage"
             x:CompileBindings="False"
             Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <Grid Margin="10" RowDefinitions="Auto,Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                <TextBlock VerticalAlignment="Center"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Text="前台包管理" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding PackageCountText}" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding Status}" />
            </StackPanel>
            <Button Grid.Column="1"
                    Margin="0,0,10,0"
                    Command="{Binding ReloadPackagesCommand}"
                    Content="刷新" />
            <Button Grid.Column="2"
                    Click="ImportPackageButton_OnClick"
                    Content="导入 ZIP 前台包" />
        </Grid>

        <TextBlock Grid.Row="1"
                   Margin="0,8,0,12"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Text="前台包会自动加载到 wwwroot/frontends；/bp-layout 根据 frontend 和 page 参数打开页面，不需要手动编辑 proxies.json。"
                   TextWrapping="Wrap" />

        <ScrollViewer Grid.Row="2">
            <ItemsControl ItemsSource="{Binding Packages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10"
                                Padding="14"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8">
                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto,Auto">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding Name}" />
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Text="{Binding Id, StringFormat=ID: {0}}" />
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Text="{Binding Version, StringFormat=Version: {0}}" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Margin="10,0,0,0"
                                        Click="OpenPackageButton_OnClick"
                                        Content="打开默认页" />
                                <Button Grid.Column="2"
                                        Margin="10,0,0,0"
                                        Command="{Binding DataContext.CopyUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding LaunchUrl}"
                                        Content="复制地址" />

                                <TextBox Grid.Row="1"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="3"
                                         Margin="0,10,0,0"
                                         IsReadOnly="True"
                                         Text="{Binding LaunchUrl}" />

                                <ItemsControl Grid.Row="2"
                                              Grid.Column="0"
                                              Grid.ColumnSpan="3"
                                              Margin="0,10,0,0"
                                              ItemsSource="{Binding Pages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,6" ColumnDefinitions="180,*,Auto,Auto">
                                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Name}" />
                                                <TextBlock Grid.Column="1"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                           Text="{Binding Layout}" />
                                                <Button Grid.Column="2"
                                                        Margin="10,0,0,0"
                                                        Click="OpenPageButton_OnClick"
                                                        Content="打开" />
                                                <Button Grid.Column="3"
                                                        Margin="10,0,0,0"
                                                        Command="{Binding DataContext.CopyUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding LaunchUrl}"
                                                        Content="复制" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
