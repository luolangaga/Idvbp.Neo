<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Idvbp.Neo.Views.Pages.WebProxyPage"
             x:CompileBindings="False"
             Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <Grid Margin="10" RowDefinitions="Auto,Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                <TextBlock VerticalAlignment="Center"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Text="窗口管理" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding FrontendPackageCountText}" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding Status}" />
            </StackPanel>
            <Button Grid.Column="1"
                    Margin="0,0,10,0"
                    Command="{Binding ReloadConfigCommand}"
                    Content="刷新" />
            <Button Grid.Column="2"
                    Margin="0,0,10,0"
                    Click="ImportFrontendPackageButton_OnClick"
                    Content="导入前台 ZIP" />
        </Grid>

        <TextBlock Grid.Row="1"
                   Margin="0,8,0,12"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Text="前台包自动扫描 wwwroot/frontends，可通过 /bp-layout?frontend=包ID&amp;page=页面ID 打开，并可在这里管理窗口、页面配置和布局。"
                   TextWrapping="Wrap" />

        <ScrollViewer Grid.Row="2" MaxHeight="360">
            <ItemsControl ItemsSource="{Binding FrontendPackages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10"
                                Padding="14"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*">
                                <WrapPanel Grid.Row="0">
                                    <TextBlock Margin="0,0,10,4"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="{Binding Name}" />
                                    <TextBlock Margin="0,0,10,4"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Text="{Binding Id, StringFormat=ID: {0}}" />
                                    <TextBlock Margin="0,0,0,4"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Text="{Binding Version, StringFormat=Version: {0}}" />
                                </WrapPanel>

                                <WrapPanel Grid.Row="1"
                                           Margin="0,10,0,0"
                                           HorizontalAlignment="Right">
                                    <Button Margin="0,0,10,8"
                                            Click="OpenFrontendPackageButton_OnClick"
                                            Content="打开窗口" />
                                    <Button Margin="0,0,10,8"
                                            Command="{Binding DataContext.CopyFrontendUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding LaunchUrl}"
                                            Content="复制地址" />
                                    <Button Margin="0,0,0,8"
                                            Click="ExportFrontendPackageButton_OnClick"
                                            Content="导出 ZIP" />
                                </WrapPanel>

                                <TextBox Grid.Row="2"
                                         Margin="2,2,2,0"
                                         IsReadOnly="True"
                                         Text="{Binding LaunchUrl}" />

                                <ItemsControl Grid.Row="3"
                                              Margin="0,10,0,0"
                                              ItemsSource="{Binding Pages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,10" RowDefinitions="Auto,Auto">
                                                <WrapPanel Grid.Row="0"
                                                           HorizontalAlignment="Right">
                                                    <Button Margin="0,0,10,6"
                                                            Click="EditFrontendPageConfigButton_OnClick"
                                                            Content="编辑配置" />
                                                    <Button Margin="0,0,0,6"
                                                            Click="EditFrontendLayoutButton_OnClick"
                                                            Content="编辑布局" />
                                                    <Button Margin="10,0,0,6"
                                                            Click="OpenComponentDesignerButton_OnClick"
                                                            Content="组件设计器" />
                                                </WrapPanel>

                                                <WrapPanel Grid.Row="1">
                                                    <TextBlock Margin="0,0,16,4"
                                                               MinWidth="160"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding Name}" />
                                                    <TextBlock Margin="0,0,16,4"
                                                               MaxWidth="320"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Text="{Binding Layout}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Margin="0,0,16,4"
                                                               MinWidth="130"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Text="{Binding ViewportSummary}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Margin="0,0,0,4"
                                                               MaxWidth="360"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Text="{Binding PageConfigSummary, StringFormat=配置摘要: {0}}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </WrapPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</UserControl>
