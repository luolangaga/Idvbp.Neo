<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Idvbp.Neo.Views.Pages.PickPage"
             x:CompileBindings="False"
             Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <ScrollViewer>
        <StackPanel Margin="10,0,10,10">
            <WrapPanel Orientation="Horizontal">
                <Border MinWidth="820" MaxWidth="1120" Classes="Card">
                    <Grid RowDefinitions="Auto,*">
                        <StackPanel Grid.Row="0">
                            <TextBlock Classes="Title" Text="选择求生者" />
                            <TextBlock Margin="0,6,0,0" Text="{Binding SurvivorTeamName}" />
                        </StackPanel>
                        <ItemsControl Grid.Row="1" Margin="0,12,0,0" ItemsSource="{Binding SurPickList}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="255" Margin="0,0,10,10" Padding="10" Classes="Card">
                                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
                                            <StackPanel Grid.Row="0">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding SlotTitle}" />
                                                <TextBlock Margin="0,2,0,0" FontSize="12" Opacity="0.75" Text="{Binding TeamName}" />
                                            </StackPanel>

                                            <Grid Grid.Row="1" Margin="0,8,0,0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <TextBox Grid.Column="0"
                                                         Watermark="搜索，如 zss"
                                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                         KeyDown="OnCharacterSearchKeyDown" />
                                                <Button Grid.Column="1"
                                                        MinWidth="68"
                                                        Command="{Binding ConfirmSelectionCommand}"
                                                        Content="确认"
                                                        IsEnabled="{Binding CanConfirmSelection}" />
                                            </Grid>

                                            <TextBlock Grid.Row="2"
                                                       Margin="0,6,0,0"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding PendingCharacter.DisplayName, TargetNullValue=未匹配到角色}" />

                                            <ListBox Grid.Row="3"
                                                     Height="108"
                                                     Margin="0,6,0,0"
                                                     ItemsSource="{Binding FilteredCharacters}"
                                                     SelectedItem="{Binding PendingCharacter}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock FontSize="12" Text="{Binding DisplayName}" />
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>

                                            <Grid Grid.Row="4" Margin="0,6,0,0" ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       Opacity="0.7"
                                                       Text="{Binding SubmitStateText}" />
                                                <Image Grid.Column="1"
                                                   Height="112"
                                                   MaxWidth="112"
                                                   Margin="8,0,0,0"
                                                   HorizontalAlignment="Center"
                                                   Source="{Binding SelectedCharacterPreviewImage}"
                                                   Stretch="Uniform" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <Border Width="320" Classes="Card">
                    <Grid RowDefinitions="Auto,*">
                        <StackPanel Grid.Row="0">
                            <TextBlock Classes="Title" Text="选择监管者" />
                            <TextBlock Margin="0,6,0,0" Text="{Binding HunterTeamName}" />
                        </StackPanel>
                        <Grid Grid.Row="1" Margin="0,10,0,0" RowDefinitions="Auto,Auto,Auto,Auto,*">
                            <StackPanel Grid.Row="0">
                                <TextBlock FontWeight="SemiBold" Text="{Binding HunPickVm.SlotTitle}" />
                                <TextBlock Margin="0,2,0,0" FontSize="12" Opacity="0.75" Text="{Binding HunPickVm.TeamName}" />
                            </StackPanel>

                            <Grid Grid.Row="1" Margin="0,8,0,0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox Grid.Column="0"
                                         Watermark="搜索，如 gjyy"
                                         Text="{Binding HunPickVm.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         KeyDown="OnCharacterSearchKeyDown" />
                                <Button Grid.Column="1"
                                        MinWidth="68"
                                        Command="{Binding HunPickVm.ConfirmSelectionCommand}"
                                        Content="确认"
                                        IsEnabled="{Binding HunPickVm.CanConfirmSelection}" />
                            </Grid>

                            <TextBlock Grid.Row="2"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Text="{Binding HunPickVm.PendingCharacter.DisplayName, TargetNullValue=未匹配到角色}" />

                            <ListBox Grid.Row="3"
                                     Height="108"
                                     Margin="0,6,0,0"
                                     ItemsSource="{Binding HunPickVm.FilteredCharacters}"
                                     SelectedItem="{Binding HunPickVm.PendingCharacter}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="12" Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Grid Grid.Row="4" Margin="0,6,0,0" ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Opacity="0.7"
                                       Text="{Binding HunPickVm.SubmitStateText}" />
                                <Border Grid.Column="1"
                                        Width="128"
                                        Height="72"
                                        Margin="8,0,0,0"
                                        ClipToBounds="True">
                                    <Image HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           Source="{Binding HunPickVm.SelectedCharacterPreviewImage}"
                                           Stretch="UniformToFill" />
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <Border Width="320" Classes="Card">
                    <Grid RowDefinitions="Auto,*">
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Classes="Title" Text="选择框状态" />
                            <ToggleSwitch Margin="10,0,0,0" IsChecked="{Binding IsSingleControlEnabled}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Margin="0,10,0,0">
                            <TextBlock Text="这里保留选择框开关配置，方便后续继续接入前端展示层。" TextWrapping="Wrap" />
                            <CheckBox Margin="0,10,0,0" Content="分别控制前两个选择框" IsChecked="{Binding IsSingleControlEnabled}" />
                            <CheckBox Margin="0,10,0,0" Content="求生者选择框 1" IsChecked="{Binding SurPickingBorder1}" />
                            <CheckBox Margin="0,10,0,0" Content="求生者选择框 2" IsChecked="{Binding SurPickingBorder2}" />
                            <CheckBox Margin="0,10,0,0" Content="求生者选择框 3" IsChecked="{Binding SurPickingBorder3}" />
                            <CheckBox Margin="0,10,0,0" Content="求生者选择框 4" IsChecked="{Binding SurPickingBorder4}" />
                            <CheckBox Margin="0,10,0,0" Content="监管者选择框" IsChecked="{Binding HunPickingBorder}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border MinWidth="620" MaxWidth="920" Classes="Card">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                        <TextBlock Grid.Row="0" Classes="Title" Text="禁用记录" />
                        <CheckBox Grid.Row="1" Margin="0,10,0,0" Content="自动记录" IsChecked="{Binding IsGlobalBanAutoRecord}" />

                        <Grid Grid.Row="2" Margin="0,14,0,0" ColumnDefinitions="*,*">
                            <StackPanel Grid.Column="0">
                                <TextBlock FontWeight="SemiBold" Text="{Binding MainTeamName}" />
                                <TextBlock Margin="0,10,0,0" Text="全局禁用求生者" />
                                <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding HomeSurGlobalBanRecords}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="0,0,0,6" Text="{Binding CharacterName}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Margin="0,10,0,0" Text="全局禁用监管者" />
                                <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding HomeHunGlobalBanRecords}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="0,0,0,6" Text="{Binding CharacterName}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="20,0,0,0">
                                <TextBlock FontWeight="SemiBold" Text="{Binding AwayTeamName}" />
                                <TextBlock Margin="0,10,0,0" Text="当前局禁用求生者" />
                                <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding AwaySurGlobalBanRecords}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="0,0,0,6" Text="{Binding CharacterName}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Margin="0,10,0,0" Text="当前局禁用监管者" />
                                <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding AwayHunGlobalBanRecords}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="0,0,0,6" Text="{Binding CharacterName}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>

                        <TextBlock Grid.Row="3"
                                   Margin="0,14,0,0"
                                   Text="注：当前后端模型只提供房间级全局 Ban 和当前局 Ban，所以这里按现有数据结构做稳定映射展示。"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Border>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
