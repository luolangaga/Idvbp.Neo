<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Idvbp.Neo.Views.Pages.HomePage"
             x:CompileBindings="False"
             Foreground="{DynamicResource TextFillColorTertiaryBrush}">
    <ScrollViewer>
        <Grid RowDefinitions="Auto,Auto,Auto" MaxWidth="900">
            <!-- 头部横幅 -->
            <Border Grid.Row="0" VerticalAlignment="Top" CornerRadius="4">
                <Grid Height="180" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Margin="35,0,0,30"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom">
                        <TextBlock FontSize="25" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Text="Idvbp.Neo"/>
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="15"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="第五人格赛事直播的终极解决方案"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 房间管理 -->
            <Border Grid.Row="1" Margin="0,16,0,0" Padding="20" CornerRadius="6"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                <Grid RowDefinitions="Auto,Auto,Auto">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
                        <TextBlock FontSize="18" FontWeight="Bold" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Text="比赛房间管理"/>
                        <Button Content="刷新全部" Command="{Binding LoadAllRoomsCommand}"
                                Classes="Secondary" Margin="20,0,0,0"/>
                    </StackPanel>

                    <!-- 新建房间表单 -->
                    <Border Grid.Row="1" Margin="0,12,0,0" Padding="14" CornerRadius="4"
                            Background="{DynamicResource SubtleFillColorTransparentBrush}">
                        <StackPanel Spacing="8">
                            <TextBlock FontWeight="SemiBold" Text="新建比赛房间"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBox Width="180" Watermark="房间名称" Text="{Binding NewRoomName}"/>
                                <TextBox Width="120" Watermark="主队" Text="{Binding NewTeamAName}"/>
                                <TextBox Width="120" Watermark="客队" Text="{Binding NewTeamBName}"/>
                                <Button Content="创建" Command="{Binding CreateRoomCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 房间列表 -->
                    <Border Grid.Row="2" Margin="0,12,0,0" Padding="6"
                            MaxHeight="360" CornerRadius="4"
                            Background="{DynamicResource SubtleFillColorTransparentBrush}">
                        <ScrollViewer>
                            <ItemsControl x:Name="RoomListControl" ItemsSource="{Binding Rooms}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="4" Padding="12,8" CornerRadius="4"
                                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                                            <Grid ColumnDefinitions="*,120,Auto,Auto,Auto">
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                               Text="{Binding RoomName}"/>
                                                    <TextBlock FontSize="12"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Text="{Binding RoomId}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock FontSize="13"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                                        <Run Text="第 "/><Run Text="{Binding CurrentRound}"/><Run Text=" 局 · "/><Run Text="{Binding CurrentPhase}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <Button Grid.Column="2" Margin="4,0"
                                                        Content="切换" Classes="Secondary"
                                                        Click="SwitchRoom_Click"
                                                        Tag="{Binding RoomId}"/>
                                                <Button Grid.Column="3" Margin="4,0"
                                                        Content="删除"
                                                        Click="DeleteRoom_Click"
                                                        Tag="{Binding RoomId}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <!-- 发布说明 -->
            <Expander Grid.Row="2" Margin="0,16,0,0"
                      VerticalAlignment="Stretch"
                      IsExpanded="{Binding IsExpanded}">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="发布说明"/>
                    </StackPanel>
                </Expander.Header>
                <ScrollViewer MinHeight="0">
                    <TextBlock Text="{Binding ReleaseNotes}" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Expander>
        </Grid>
    </ScrollViewer>
</UserControl>
