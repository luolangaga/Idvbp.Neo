<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ic="clr-namespace:FluentIcons.Avalonia.Fluent;assembly=FluentIcons.Avalonia.Fluent"
        xmlns:md="clr-namespace:Markdown.Avalonia;assembly=Markdown.Avalonia"
        mc:Ignorable="d"
        x:Class="Idvbp.Neo.Views.ErrorReportWindow"
        x:CompileBindings="False"
        d:DesignWidth="760"
        d:DesignHeight="620"
        Width="760"
        Height="620"
        MinWidth="680"
        MinHeight="520"
        Title="错误报告"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Grid Margin="22" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="16">
        <Border Grid.Row="0"
                Padding="18"
                Background="#2C1A1F"
                BorderBrush="#8F4B57"
                BorderThickness="1"
                CornerRadius="8">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                <Border Width="42"
                        Height="42"
                        Background="#B83A4B"
                        CornerRadius="8">
                    <ic:FluentIcon HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="White"
                                   FontSize="24"
                                   Icon="ErrorCircle" />
                </Border>

                <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Text="程序遇到错误" />
                    <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="错误信息已经整理好，可以复制、打包，或直接打开 GitHub Issue 页面提交反馈。"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Padding="14"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
                <TextBlock FontSize="16"
                           FontWeight="SemiBold"
                           Text="{Binding ErrorTitle}"
                           TextWrapping="Wrap" />
                <TextBlock Grid.Row="1"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding ErrorSubtitle}"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid RowDefinitions="Auto,*">
                <Border Padding="12,10"
                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="8,8,0,0">
                    <TextBlock FontWeight="SemiBold" Text="错误详情" />
                </Border>

                <md:MarkdownScrollViewer Grid.Row="1"
                                         Margin="12"
                                         Markdown="{Binding ErrorText}" />
            </Grid>
        </Border>

        <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <TextBlock VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="{Binding StatusText}"
                       TextWrapping="Wrap" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Click="CopyError_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ic:FluentIcon Icon="Copy" FontSize="17" />
                        <TextBlock Text="复制错误" />
                    </StackPanel>
                </Button>
                <Button Click="PackageError_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ic:FluentIcon Icon="Archive" FontSize="17" />
                        <TextBlock Text="一键打包" />
                    </StackPanel>
                </Button>
                <Button Click="ReportIssue_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ic:FluentIcon Icon="Open" FontSize="17" />
                        <TextBlock Text="提交 Issue" />
                    </StackPanel>
                </Button>
                <Button Click="Close_Click" Content="关闭" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
